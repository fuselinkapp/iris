# Shared-secret for the /api/ingest endpoint. If unset in development,
# the endpoint accepts all requests and logs a one-time warning. In
# production (NODE_ENV=production) it must be set or every request 401s.
IRIS_INGEST_TOKEN=

# Resend API key for outbound mail. Optional in dev: when unset, the
# compose form runs in dry-run mode (DB write happens, no actual send).
# Required in production for outbound to actually deliver.
RESEND_API_KEY=
